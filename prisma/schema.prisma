generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId   String?  @unique
  email     String   @unique
  name      String?
  imageUrl  String?
  role      String   @default("USER")
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([role])
}

model Studio {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId    String   @unique @db.ObjectId
  slug       String   @unique
  name       String
  bio        String?
  location   String?
  theme      Json?
  status     String   @default("DRAFT")
  isVerified Boolean  @default(false)
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([status, isFeatured])
}

model Product {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  studioId      String   @db.ObjectId
  collectionId  String?  @db.ObjectId
  slug          String   @unique
  name          String
  description   String?
  type          String
  status        String   @default("DRAFT")
  price         Int
  currency      String   @default("USD")
  inventory     Int?
  media         Json     @default("[]")
  configuration Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([studioId, status])
  @@index([collectionId])
}

model Collection {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  studioId    String   @db.ObjectId
  slug        String   @unique
  name        String
  description String?
  coverImage  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([studioId])
}

model Order {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  buyerId               String   @db.ObjectId
  studioId              String   @db.ObjectId
  status                String   @default("PENDING")
  subtotal              Int
  shippingAmount        Int      @default(0)
  total                 Int
  currency              String   @default("USD")
  stripePaymentIntentId String?  @unique
  shippingAddress       Json?
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  @@index([buyerId, createdAt])
  @@index([studioId, status])
}

model OrderItem {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId       String   @db.ObjectId
  productId     String?  @db.ObjectId
  name          String
  quantity      Int      @default(1)
  unitPrice     Int
  configuration Json?
  createdAt     DateTime @default(now())
  @@index([orderId])
}

// A cart is intentionally separate from orders: it lets a visitor return to an
// in-progress purchase and keeps checkout idempotent when a payment provider
// is added later.
model Cart {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String     @unique @db.ObjectId
  currency  String     @default("USD")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  lines     CartLine[]
  @@index([updatedAt])
}

model CartLine {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  cartId        String   @db.ObjectId
  productId     String   @db.ObjectId
  quantity      Int      @default(1)
  configuration Json?
  savedForLater Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cart          Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  @@unique([cartId, productId])
  @@index([cartId, savedForLater])
}

model Blog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  studioId    String   @db.ObjectId
  slug        String   @unique
  title       String
  body        String
  status      String   @default("DRAFT")
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([studioId, status])
}

model Video {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  studioId     String   @db.ObjectId
  title        String
  url          String
  thumbnailUrl String?
  duration     Int?
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  @@index([studioId, publishedAt])
}

model SocialAction {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  targetType String
  targetId   String   @db.ObjectId
  action     String
  parentId   String?  @db.ObjectId
  body       String?
  createdAt  DateTime @default(now())
  @@index([targetType, targetId, createdAt])
  @@unique([userId, targetType, targetId, action])
}

model Notification {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  type       String
  actorId    String?  @db.ObjectId
  entityType String?
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime @default(now())
  @@index([userId, readAt, createdAt])
}

model MessageThread {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  studioId  String   @db.ObjectId
  memberIds String[] @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([studioId, updatedAt])
}

model Message {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  threadId    String   @db.ObjectId
  senderId    String   @db.ObjectId
  body        String
  attachments Json?
  readAt      DateTime?
  createdAt   DateTime @default(now())
  @@index([threadId, createdAt])
}

model CustomizationRequest {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  productId         String   @db.ObjectId
  userId            String   @db.ObjectId
  studioId          String   @db.ObjectId
  status            String   @default("NEW")
  selections        Json
  notes             String?
  estimatedDelivery DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@index([studioId, status])
}

model BlankProduct {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  sku        String   @unique
  name       String
  description String?
  category   String
  basePrice  Int
  currency   String   @default("USD")
  variants   Json     @default("[]")
  printAreas Json     @default("[]")
  images     Json     @default("[]")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([category, active])
}

model PodDesign {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  studioId       String   @db.ObjectId
  blankProductId String   @db.ObjectId
  name           String
  artwork        Json
  status         String   @default("DRAFT")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([studioId, status])
}

model PlatformRecord {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  kind       String
  subjectId  String?  @db.ObjectId
  ownerId    String?  @db.ObjectId
  status     String   @default("OPEN")
  payload    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([kind, status, createdAt])
}
